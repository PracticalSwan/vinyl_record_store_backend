MONGODB_URI=
MONGODB_DB_NAME=vinyl_record_store
CATALOG_DATA_SOURCE=seed
FRONTEND_ORIGIN=http://localhost:5173
RECOMMENDER_ALGORITHM_VERSION=content-demo-v1
PERS_IDENTITY_STRICT=true
PERS_ME_ENDPOINT=true
MUSICBRAINZ_USER_AGENT=GroovehausAcademic/0.1 (https://github.com/PracticalSwan/vinyl_record_store_backend)
AUTH_SECRET=
AUTH_COOKIE_SECURE=false
# Showcase demo customer accounts are seeded into MongoDB by `npm run db:seed:users:apply`
# (see src/data/demoUsers.js). The AUTH_DEMO_CUSTOMER_* / AUTH_DEMO_ADMIN_* values below are an
# environment-backed fallback for seed-catalog mode; the admin account is environment-only.
# Never commit real hashes, salts, or AUTH_SECRET.
AUTH_DEMO_CUSTOMER_USERNAME=
AUTH_DEMO_CUSTOMER_DISPLAY_NAME=
AUTH_DEMO_CUSTOMER_PASSWORD_HASH=
AUTH_DEMO_CUSTOMER_PASSWORD_SALT=
AUTH_DEMO_ADMIN_USERNAME=
AUTH_DEMO_ADMIN_DISPLAY_NAME=
AUTH_DEMO_ADMIN_PASSWORD_HASH=
AUTH_DEMO_ADMIN_PASSWORD_SALT=
